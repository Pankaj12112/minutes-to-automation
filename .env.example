# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Transcription provider: assemblyai | deepgram
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=your-assemblyai-key
# DEEPGRAM_API_KEY=your-deepgram-key

# Contact directory for resolving names to emails
CONTACT_DIRECTORY_JSON={"Alice Johnson":"alice@company.com","Bob Smith":"bob@company.com"}
UNKNOWN_EMAIL_PLACEHOLDER=unknown@company.com

# Notifications: webhook | email | both
NOTIFICATION_MODE=webhook
WEBHOOK_URL=https://your-n8n-or-make-instance/webhook/meeting-actions
WEBHOOK_TIMEOUT_SECONDS=30

# SMTP (required when NOTIFICATION_MODE=email or both)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@company.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# SMTP_FROM_EMAIL=meetings@company.com

# Application
DEBUG=false
LOG_LEVEL=INFO
